# Operator Loop v0.2.1 — Environment Variables

# Anthropic API key (optional — used by Research Unit only)
# When set: Research Unit calls the real Claude API.
# When absent or on error: Research Unit falls back to demo mode automatically.
# Never expose this to the client — it is server-side only (Next.js API routes).
ANTHROPIC_API_KEY=your-api-key-here
