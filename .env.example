# Operator Loop v0.2 — Environment Variables
# Copy this file to .env.local and fill in your values.
# None of these are required to run the app — all units fall back to demo mode gracefully.

# ──────────────────────────────────────────────────────
# Anthropic API — Research Unit (Scout Unit)
# ──────────────────────────────────────────────────────
# When set: Research Unit calls the real Claude API (claude-opus-4-8).
# When absent or on error: Research Unit returns DEMO FALLBACK output.
# Server-side only — never exposed to the browser.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ──────────────────────────────────────────────────────
# Google OAuth2 — Inbox Unit (Gmail) + Schedule Unit (Calendar)
# ──────────────────────────────────────────────────────
# Required scopes:
#   https://www.googleapis.com/auth/gmail.readonly
#   https://www.googleapis.com/auth/calendar.readonly
#
# Setup steps:
#   1. Create an OAuth 2.0 Client ID in Google Cloud Console.
#   2. Enable Gmail API and Google Calendar API for your project.
#   3. Run the one-time browser consent flow to obtain a refresh token.
#      See docs/GOOGLE_READONLY_INTEGRATION.md for the full setup guide.
#   4. Paste the three values below.
#
# When set: Inbox Unit reads real Gmail; Schedule Unit reads real Calendar.
# When absent or on API error: both units return DEMO FALLBACK output.
# Server-side only — never exposed to the browser.
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here
GOOGLE_REFRESH_TOKEN=your-google-oauth-refresh-token-here
